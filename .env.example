# Zid OAuth Credentials (from Zid Partner Dashboard)
ZID_CLIENT_ID=your_client_id_here
ZID_CLIENT_SECRET=your_client_secret_here

# Must match "Callback URL" in Zid Partner Dashboard
# For local dev with ngrok: https://your-subdomain.ngrok-free.dev/auth/callback
ZID_REDIRECT_URI=http://localhost:8000/auth/callback

# Zid store ID — required for products to work
ZID_STORE_ID=your_store_id_here
